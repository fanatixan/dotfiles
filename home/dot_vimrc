set nocompatible

" Plugins — list lives in ~/.vim/plugins.vim (chezmoi reinstalls on change)
call plug#begin('~/.vim/plugged')
source ~/.vim/plugins.vim
call plug#end()

filetype plugin indent on
" tmux-256color terminfo omits the background-query capability vim uses to
" auto-detect light/dark, so under tmux vim falls back to background=light and
" loads the light variant of the default colorscheme (dark blue/brown) onto
" Ghostty's dark background. Pin it so colors match in and out of tmux.
set background=dark
syntax on
set number relativenumber            " hybrid line numbers
set hidden                           " switch buffers without saving
set incsearch hlsearch ignorecase smartcase
set scrolloff=5
set mouse=a
set splitright splitbelow
set wildmenu
set termguicolors                    " 24-bit color
" Truecolor under tmux: tmux-256color terminfo doesn't advertise RGB, so Vim
" needs the set-foreground/background sequences spelled out explicitly.
let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
set clipboard=unnamed                " yank -> Mac pasteboard (host-local)

let mapleader = " "                  " leader = Space

" fzf (uses ripgrep + fd)
let $FZF_DEFAULT_COMMAND = 'fd --type f --hidden --follow --exclude .git'
nnoremap <leader>f :Files<CR>
nnoremap <leader>b :Buffers<CR>
nnoremap <leader>/ :Rg<CR>           " search file contents
nnoremap <leader>l :BLines<CR>

" NERDTree
nnoremap <leader>e :NERDTreeToggle<CR>
nnoremap <leader>n :NERDTreeFind<CR>
let NERDTreeShowHidden = 1
autocmd BufEnter * if winnr('$') == 1 && exists('b:NERDTree') && b:NERDTree.isTabTree() | quit | endif

" OSC52: every yank also goes to the client clipboard over SSH
autocmd TextYankPost * if v:event.operator is 'y' && v:event.regname is ''
      \ | call OSCYankRegister('"') | endif
vnoremap <leader>y :OSCYankVisual<CR>

" Window navigation
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Quality of life
nnoremap <leader>w :w<CR>
nnoremap <leader>q :q<CR>
nnoremap <silent> <esc><esc> :nohlsearch<CR>

" Cheat sheet (glow in :term split; q closes via ++close).
" expand() resolves ~ — vim's :term passes argv literally and won't do it.
" env TERM=tmux-256color: vim's :term otherwise forces TERM=xterm-256color,
" which breaks tmux's truecolor passthrough for the nested glow and down-samples
" its colors to 256. Matching the TERM that glow sees when run directly in tmux
" (where the tmux cheatsheet renders correctly) restores truecolor.
nnoremap <leader>? :execute 'vert term ++close env TERM=tmux-256color glow -p ' . expand('~/cheatsheets/vim/general.md')<CR>
