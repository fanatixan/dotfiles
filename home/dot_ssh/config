Host mac-m4
  HostName mac-m4.clients.lan
  User attila
  ForwardAgent yes
  # Reuse one connection for all sessions
  ControlMaster auto
  ControlPath ~/.ssh/cm-%C # %C: short hash (avoids macOS 104-char socket limit)
  ControlPersist 10m
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host node-1
  HostName node-1.lab.lan
  User attila
  IdentityFile ~/.ssh/homelab/node-1.pub
  IdentitiesOnly yes

